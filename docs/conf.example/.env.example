# ======================================================================
# codesaur's Raptor framework
# ======================================================================

# ----------------------------------------------------------------------
# Environment & App Settings
# ----------------------------------------------------------------------

# Аппликейшний нэр
CODESAUR_APP_NAME=raptor

# Хэрэглэж буй орчны төрөл (development, production)
CODESAUR_APP_ENV=development

# Цагийн бүс (жишээ: Asia/Ulaanbaatar)
#CODESAUR_APP_TIME_ZONE=Asia/Ulaanbaatar


# ----------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------

# Өгөгдлийн сангийн driver: mysql | pgsql
RAPTOR_DB_DRIVER=mysql

# Өгөгдлийн сангийн серверийн хаяг
RAPTOR_DB_HOST=localhost

# Өгөгдлийн сангийн нэр
RAPTOR_DB_NAME=raptor

# Холбогдох хэрэглэгчийн нэр
RAPTOR_DB_USERNAME=root

# Холбогдох хэрэглэгчийн нууц үг
RAPTOR_DB_PASSWORD=

# Өгөгдлийн сангийн charset
RAPTOR_DB_CHARSET=utf8mb4

# Өгөгдлийн сангийн collation
RAPTOR_DB_COLLATION=utf8mb4_unicode_ci

# Холболтыг байнгын (persistent) байлгах эсэх (true/false)
RAPTOR_DB_PERSISTENT=false


# ----------------------------------------------------------------------
# JSON Web Token (JWT)
# ----------------------------------------------------------------------

# JWT алгоритм (жишээ: HS256, HS384, HS512, RS256)
RAPTOR_JWT_ALGORITHM=HS256

# JWT хүчинтэй байх хугацаа (секундээр, 2592000 = 30 хоног)
RAPTOR_JWT_LIFETIME=2592000

# JWT secret key
# Composer-ын post-install script автоматаар үүсгэнэ.
RAPTOR_JWT_SECRET=will-be-auto-generated-during-composer-post-install

# Серверийн цагийн багахан зөрөөг зөвшөөрөх хугацаа (секундээр)
#RAPTOR_JWT_LEEWAY=10


# ----------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------

# Нууц үг сэргээх холбоосын хүчинтэй хугацаа (минутаар)
RAPTOR_PASSWORD_RESET_MINUTES=10


# ----------------------------------------------------------------------
# Shared Hosting / WAF Compatibility
# ----------------------------------------------------------------------

# Session-г хадгалах зам (cPanel/LiteSpeed-ийн shared /tmp-г system cron цэвэрлэдгээс сэргийлнэ)
# Хоосон = үед төслийн protected/sessions автоматаар авагдана.
# Зам үнэмлэхүй (absolute) бас бичих боломжтой (writable) байх ёстой
# Жишээ - Linux: /home/user/sessions ; Windows: C:/xampp/tmp/sessions
RAPTOR_SESSION_SAVE_PATH=

# Session cookie болон server-side gc амьдрах хугацаа (секундээр, 2592000 = 30 хоног).
# Хэт богино бол session устаж CSRF token алдагдан mutating хүсэлт 403 өгдөг.
RAPTOR_SESSION_LIFETIME=2592000

# mod_security зэрэг WAF нь POST body доторх HTML/JS-төстэй агуулгыг (rich-text
# content, <a>, <img>, <script>) XSS халдлага гэж андуурч 403 буцаадаг. true бол
# client (csrfFetch) form талбаруудыг base64-аар кодолж WAF-аас нуудаг; server
# тал (BodyEncodingMiddleware) буцааж decode хийнэ. WAF-гүй сервер дээр false.
RAPTOR_WAF_BODY_ENCODING=true


# ----------------------------------------------------------------------
# Mail Configuration
# ----------------------------------------------------------------------

# Илгээх арга: brevo (анхдагч), smtp, mail
#RAPTOR_MAIL_TRANSPORT=brevo

# Brevo API түлхүүр (transport=brevo үед заавал)
#RAPTOR_MAIL_BREVO_APIKEY=

# SMTP тохиргоо (transport=smtp үед заавал)
#RAPTOR_SMTP_HOST=smtp.gmail.com
#RAPTOR_SMTP_PORT=465
#RAPTOR_SMTP_USERNAME=
#RAPTOR_SMTP_PASSWORD=
#RAPTOR_SMTP_SECURE=ssl

# Илгээх и-мэйл хаяг
RAPTOR_MAIL_FROM=noreply@codesaur.net

# Илгээх и-мэйл дээр харуулах нэр
#RAPTOR_MAIL_FROM_NAME="Raptor Notification"

# Хариу авах и-мэйл хаяг
#RAPTOR_MAIL_REPLY_TO=

# Хариу авах нэр
#RAPTOR_MAIL_REPLY_TO_NAME=

# Email мэдэгдэл (хаяг бичвэл on, хоосон бол off)
RAPTOR_CONTACT_EMAIL_TO=
RAPTOR_ORDER_EMAIL_TO=
RAPTOR_COMMENT_EMAIL_TO=
RAPTOR_REVIEW_EMAIL_TO=


# ----------------------------------------------------------------------
# Content Image Optimization
# ----------------------------------------------------------------------

# Зургийн хамгийн их өргөн (px)
RAPTOR_CONTENT_IMG_MAX_WIDTH=1920

# JPEG/WebP чанар (1-100). 90 нь өнгө хадгалахад сайн
RAPTOR_CONTENT_IMG_QUALITY=90


# ----------------------------------------------------------------------
# OpenAI API Configuration
# ----------------------------------------------------------------------

# OpenAI API түлхүүр: https://platform.openai.com/api-keys
# moedit editor-ийн AI товчинд ашиглагдана
#RAPTOR_OPENAI_API_KEY=sk-your-api-key-here


# ----------------------------------------------------------------------
# Discord Webhook Notification
# ----------------------------------------------------------------------

# Discord Webhook URL (хоосон бол мэдэгдэл илгээхгүй)
#RAPTOR_DISCORD_WEBHOOK_URL=


# ----------------------------------------------------------------------
# Cloudflare Turnstile (хоосон бол Turnstile ашиглахгүй)
# - Cloudflare-ийн албан ёсны тест түлхүүрүүд (https://developers.cloudflare.com/turnstile/troubleshooting/testing/)
# - Test sitekey -> 1x00000000000000000000AA - Always passes
# - Test secret key -> 1x0000000000000000000000000000000AA - Always passes validation
# ----------------------------------------------------------------------

#RAPTOR_TURNSTILE_SITE_KEY=
#RAPTOR_TURNSTILE_SECRET_KEY=
