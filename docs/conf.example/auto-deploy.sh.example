#!/bin/bash
# Cron автомат deploy (Terminal/SSH-гүй орчинд). .cpanel.yml-тэй яг адил
# алхмуудыг давтана. Зөвхөн шинэ commit байвал ажиллана.
# Өөрийгөө шинэчлэх аюулгүй: бүх логик main() дотор - bash функцийг бүтнээр
# уншаад ажиллуулдаг тул git reset энэ файлыг дунд нь сольсон ч эвдрэхгүй.
#
# Ашиглахын өмнө: доорх USERNAME/PROJECT/BRANCH-ийг хостоороо тохируулж бич,
# дараа нь cPanel -> Cron Jobs-д (N=2-5 минут):
#   */5 * * * * /bin/bash /home/USERNAME/repositories/PROJECT/deploy/auto-deploy.sh
set -u

# --- Тохиргоо (төсөл болгон засах) --------------------------------------
REPO="/home/USERNAME/repositories/PROJECT"   # cPanel "Repository Path"
DEPLOYPATH="/home/USERNAME"                  # .cpanel.yml дахь DEPLOYPATH
BRANCH="main"
LOG="/home/USERNAME/logs/auto-deploy.log"
LOCK="/tmp/PROJECT-auto-deploy.lock"
# ------------------------------------------------------------------------

ts() { date '+%Y-%m-%d %H:%M:%S'; }

main() {
    mkdir -p "$(dirname "$LOG")"
    exec 9>"$LOCK"                              # зэрэг 2 cron давхцахаас сэргийлэх lock
    if ! flock -n 9; then
        echo "[$(ts)] busy - өмнөх ажил дуусаагүй, алгаслаа" >> "$LOG"; return 0
    fi
    cd "$REPO" || { echo "[$(ts)] ERROR: repo олдсонгүй: $REPO" >> "$LOG"; return 1; }

    # Fetch-ийн алдааг OFFLINE тэмдэг файлаар төлөвжүүлж логлоно. GitHub-д
    # холбогдож чадахгүй үед cron бүр fatal мөр нэмээд лог замбараагүй
    # томрохын оронд тасралт эхлэхэд 1 мөр, сэргэхэд 1 мөр л бичнэ
    # (завсрын давтан алдаанууд чимээгүй алгасна).
    local OFFLINE="${LOCK%.lock}.offline" FETCH_ERR
    if ! FETCH_ERR=$(git fetch origin "$BRANCH" --quiet 2>&1); then
        if [ ! -f "$OFFLINE" ]; then
            echo "[$(ts)] ERROR: git fetch амжилтгүй, сэргэтэл дахин мэдэгдэхгүй: ${FETCH_ERR%%$'\n'*}" >> "$LOG"
            : > "$OFFLINE"
        fi
        return 1
    fi
    if [ -f "$OFFLINE" ]; then
        echo "[$(ts)] git fetch сэргэв - GitHub холболт хэвийн боллоо" >> "$LOG"
        rm -f "$OFFLINE"
    fi

    local LOCAL REMOTE
    LOCAL=$(git rev-parse HEAD); REMOTE=$(git rev-parse "origin/$BRANCH")
    [ "$LOCAL" = "$REMOTE" ] && return 0        # шинэ commit алга -> чимээгүй гарна

    echo "[$(ts)] шинэ commit: $LOCAL -> $REMOTE, deploy эхэлж байна" >> "$LOG"

    # composer.lock / composer.json өөрчлөгдсөн эсэхийг reset-ээс өмнө тогтооно
    local COMPOSER_LOCK_CHANGED=0 COMPOSER_JSON_CHANGED=0 CHANGED
    CHANGED=$(git diff --name-only "$LOCAL" "$REMOTE")
    echo "$CHANGED" | grep -q '^composer\.lock$' && COMPOSER_LOCK_CHANGED=1
    echo "$CHANGED" | grep -q '^composer\.json$' && COMPOSER_JSON_CHANGED=1

    git reset --hard "origin/$BRANCH" >>"$LOG" 2>&1   # 1) Update from Remote

    {                                                  # 2) Deploy (.cpanel.yml-тэй адил)
        /bin/rm -rf "$DEPLOYPATH/application" && /bin/cp -a application "$DEPLOYPATH/application"
        /bin/cp -af public_html/. "$DEPLOYPATH/public_html/"
        /bin/cp -f composer.json "$DEPLOYPATH/composer.json"
        /bin/cp -f composer.lock "$DEPLOYPATH/composer.lock"
        /bin/cp -f README.md "$DEPLOYPATH/README.md"
        /bin/cp -f CHANGELOG.md "$DEPLOYPATH/CHANGELOG.md"
    } >>"$LOG" 2>&1

    # 3) Composer: lock -> install; зөвхөн json -> dump-autoload -o (PSR-4 map).
    # CLI PHP-г тусад нь олно (cron-ийн php нь CGI SAPI байвал composer унана).
    if [ "$COMPOSER_LOCK_CHANGED" -eq 1 ] || [ "$COMPOSER_JSON_CHANGED" -eq 1 ]; then
        local PHP_CLI="" p
        for p in /usr/local/bin/php $(ls -1 /opt/cpanel/ea-php*/root/usr/bin/php 2>/dev/null | sort -r); do
            if [ -x "$p" ] && [ "$("$p" -r 'echo PHP_SAPI;' 2>/dev/null)" = "cli" ]; then
                PHP_CLI="$p"; break
            fi
        done
        if [ -n "$PHP_CLI" ]; then
            if [ "$COMPOSER_LOCK_CHANGED" -eq 1 ]; then
                echo "[$(ts)] composer.lock -> composer install ($PHP_CLI)" >> "$LOG"
                "$PHP_CLI" /opt/cpanel/composer/bin/composer install --no-dev \
                    --optimize-autoloader --no-interaction --working-dir="$DEPLOYPATH" >>"$LOG" 2>&1 || true
            else
                echo "[$(ts)] composer.json -> composer dump-autoload -o ($PHP_CLI)" >> "$LOG"
                "$PHP_CLI" /opt/cpanel/composer/bin/composer dump-autoload --optimize \
                    --no-interaction --working-dir="$DEPLOYPATH" >>"$LOG" 2>&1 || true
            fi
        else
            echo "[$(ts)] Анхаар: CLI PHP олдсонгүй, composer алгаслаа" >> "$LOG"
        fi
    fi
    echo "[$(ts)] deploy дуусав ($(git rev-parse --short HEAD))" >> "$LOG"
}
main "$@"
