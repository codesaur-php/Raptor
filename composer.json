{
    "name": "codesaur/raptor",
    "type": "project",
    "description": "Цэвэр архитектуртай объект хандалттай веб хөгжүүлэлтийн фреймворк",
    "keywords": [
        "raptor", "framework", "фреймворк", "application", "http application", "router", "server request handler", "psr-3", "psr-7", "psr-14", "psr-15", "psr-16", "rbac", "role based access control", "хэрэглэгчийн эрхийн зохицуулалт", "logger", "протокол", "trash", "хогийн сав", "cache", "кэш", "event dispatcher", "mailer", "smtp", "и-мэйл", "mongol", "mongolia", "монгол", "codesaur", "narankhuu", "coden", "кодзавр", "наранхүү", "коден"
    ],
    "homepage": "https://codesaur.net",
    "authors": [
        {
            "name": "Narankhuu (+976 99000287)",
            "email": "codesaur@gmail.com",
            "homepage": "https://github.com/codesaur"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "ext-gd": "*",
        "ext-intl": "*",
        
        "psr/log": "^3.0.2",
        "psr/simple-cache": "^3.0",
        "psr/event-dispatcher": "^1.0",
        "vlucas/phpdotenv": "^5.6.2",
        "firebase/php-jwt": "^7.0.2",

        "codesaur/http-application": "^6.0.2",
        "codesaur/dataobject": "^10.0.0",
        "codesaur/http-client": "^2.1.0",
        "codesaur/template": "^4.0.1",
        "codesaur/container": "^3.1.3"
    },
    "autoload": {
        "psr-4": {
            "Web\\": "application/web/",
            "Web\\Content\\": "application/web/content/",
            "Web\\Shop\\": "application/web/shop/",
            "Web\\Service\\": "application/web/service/",
            "Web\\Template\\": "application/web/template/",

            "Dashboard\\": "application/dashboard/",
            "Dashboard\\Home\\": "application/dashboard/home",
            "Dashboard\\Shop\\": "application/dashboard/shop",
            "Dashboard\\Manual\\": "application/dashboard/manual",
            
            "Raptor\\": "application/raptor/",
            "Raptor\\Exception\\": "application/raptor/exception/",
            "Raptor\\Template\\": "application/raptor/template/",
            "Raptor\\Authentication\\": "application/raptor/authentication/",
            "Raptor\\User\\": "application/raptor/user/",
            "Raptor\\Organization\\": "application/raptor/organization/",
            "Raptor\\RBAC\\": "application/raptor/rbac/",
            "Raptor\\Localization\\": [
                "application/raptor/localization/",
                "application/raptor/localization/language",
                "application/raptor/localization/text"
            ],
            "Raptor\\Content\\": [
                "application/raptor/content/",
                "application/raptor/content/settings",
                "application/raptor/content/reference",
                "application/raptor/content/file",
                "application/raptor/content/news",
                "application/raptor/content/page",
                "application/raptor/content/messages"
            ],
            "Raptor\\Notification\\": "application/raptor/notification/",
            "Raptor\\Mail\\": "application/raptor/mail/",
            "Raptor\\Log\\": "application/raptor/log/",
            "Raptor\\Development\\": "application/raptor/development/",
            "Raptor\\Migration\\": "application/raptor/migration/",
            "Raptor\\Trash\\": "application/raptor/trash/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('docs/conf.example/.env.example', '.env');\"",
            "@php -r \"$envFile='.env';$secret=bin2hex(random_bytes(64));if(file_exists($envFile)){ $content=file_get_contents($envFile);if(preg_match('/^RAPTOR_JWT_SECRET=.*/m',$content)){ $content=preg_replace('/^RAPTOR_JWT_SECRET=.*/m','RAPTOR_JWT_SECRET='.$secret,$content);} else { if(substr($content,-1)!==PHP_EOL)$content.=PHP_EOL;$content.='RAPTOR_JWT_SECRET='.$secret.PHP_EOL;} file_put_contents($envFile,$content);} else { file_put_contents($envFile,'RAPTOR_JWT_SECRET='.$secret.PHP_EOL);} echo 'RAPTOR_JWT_SECRET generated: '.$secret.PHP_EOL;\""
        ]
    },
    "license": "MIT"
}
