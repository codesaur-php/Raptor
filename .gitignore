# Public файлууд - бүх файлыг ignore хийнэ, зөвхөн .htaccess үлдээнэ
/public_html/public/*
!/public_html/public/.htaccess

# Protected protected файлууд - бүх файлыг ignore хийнэ, зөвхөн .htaccess үлдэнэ
/protected/*
!/protected/.htaccess

# Composer vendor - автоматаар татагддаг тул оруулахгүй
/vendor/
composer.lock

# Environment variables - серверийн нууц тохиргоо (DB нууц үг, API key, JWT secret гэх мэт)
# Энэ файлд системийн нэвтрэх эрх, нууц түлхүүрүүд агуулагддаг тул git-д оруулж болохгүй.
.env

# PHPUnit cache
.phpunit.cache/

# NetBeans private тохиргоо
/nbproject/private/

# Database файлууд - per-environment (file-based migration system).
# Зөвхөн .htaccess, migrations/.gitkeep ба migrations/README.md git-д үлдэнэ;
# migration SQL файлууд server-ээс upload хийгдэнэ.
/database/*
!/database/.htaccess
!/database/migrations/
/database/migrations/*
!/database/migrations/.gitkeep
!/database/migrations/README.md

# PHP error_log - сервер дээр PHP ажиллахад (ж: tidy.so missing warning)
# үүсдэг. Git clone-ийн working tree-г бохирлож, cPanel deploy-г
# "uncommitted changes"-ээр блокдог тул ignore хийнэ.
error_log
