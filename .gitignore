# Public файлууд - бүх файлыг ignore хийнэ, зөвхөн .htaccess үлдээнэ
/public_html/public/*
!/public_html/public/.htaccess

# Private хавтас - серверийн дотоод өгөгдөл, зөвхөн .htaccess үлдэнэ
/private/*
!/private/.htaccess

# Composer vendor - автоматаар татагддаг тул оруулахгүй
/vendor/
composer.lock

# Environment variables - серверийн нууц тохиргоо (DB нууц үг, API key, JWT secret гэх мэт)
# Энэ файлд системийн нэвтрэх эрх, нууц түлхүүрүүд агуулагддаг тул git-д ОРУУЛЖ БОЛОХГҮЙ.
.env

# PHPUnit cache
.phpunit.cache/

# NetBeans private тохиргоо
/nbproject/private/
