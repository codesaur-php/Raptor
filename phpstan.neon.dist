# PHPStan static analysis тохиргоо (codesaur/raptor)
#
# Энэ нь зөвхөн dev/CI үед ажилладаг static analysis - production runtime-д
# огт нөлөөлөхгүй (phpstan/phpstan нь require-dev, --no-dev deploy дээр орохгүй).
#
# Ажиллуулах:   composer phpstan       (эсвэл  vendor/bin/phpstan analyse)
# Baseline:     composer phpstan:baseline
#
# level: 0 (хамгийн зөөлөн) -> 9 (хамгийн хатуу). Консерватив 1-ээс эхэлсэн.
# Хуучин код дахь анхааруулгууд phpstan-baseline.neon-д царцаагдсан тул
# зөвхөн ШИНЭ код шалгагдана. Түвшинг дараа аажмаар өсгөж болно.

includes:
    - phpstan-baseline.neon

parameters:
    level: 1

    paths:
        - application

    bootstrapFiles:
        - phpstan-bootstrap.php

    # Динамик ($_ENV, request attribute) утгуудыг хэт хатуугаар "тодорхой" гэж
    # үзэхгүй - буруу эерэг (false positive) багасгана.
    treatPhpDocTypesAsCertain: false
